# SkillForge Backend Environment Variables
# Copy this to .env and fill in real values

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Found in Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Optional – raises GitHub API rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=your-github-personal-access-token

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-secure-random-64-char-string

DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000"]
REDIS_URL=redis://localhost:6379
